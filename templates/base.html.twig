<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="description" content="{% block meta_description %}Dice Adventure : un maître du jeu passionné anime vos sessions de jeu de rôle plateau façon Donjons & Dragons. Réunissez votre groupe, lancez les dés, vivez l'aventure.{% endblock %}">
        <title>{% block title %}{{ page_title|default('Maître du jeu — sessions de jeu de rôle plateau') }} – Dice Adventure{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221em%22 font-size=%22100%22>🎲</text></svg>">

        {# Google Fonts n'est plus chargé ici : la bannière RGPD en bas de page
           ne le charge qu'après consentement du visiteur (transmission d'IP à Google). #}

        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body>
        <header class="site-header">
            <a class="brand" href="{{ path('app_home') }}">
                {# D20 stylisé #}
                <svg class="brand__die" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="4" stroke-linejoin="round" aria-hidden="true">
                    <polygon points="50,5 90,28 90,72 50,95 10,72 10,28"/>
                    <polygon points="50,18 73,38 50,62 27,38"/>
                    <path d="M50,5 50,18 M10,28 27,38 M90,28 73,38 M27,38 10,72 M73,38 90,72 M50,62 50,95 M50,62 10,72 M50,62 90,72"/>
                </svg>
                Dice <strong>Adventure</strong>
            </a>
            <nav class="main-nav">
                {% block navigation %}
                    <ul>
                        <li><a href="{{ path('app_home') }}#aventure">L'aventure</a></li>
                        <li class="hide-mobile"><a href="{{ path('app_home') }}#news">Nouveautés</a></li>
                        <li class="hide-mobile"><a href="{{ path('app_home') }}#deroule">Comment ça marche ?</a></li>
                        <li class="hide-mobile"><a href="{{ path('app_home') }}#maitre-du-jeu">Le MJ</a></li>
                        <li><a href="{{ path('app_home') }}#formules">Formules</a></li>
                        {% if is_granted('ROLE_USER') %}
                            <li class="hide-mobile"><a href="{{ path('app_admin') }}">Admin</a></li>
                            <li><a href="{{ path('app_logout') }}">Déconnexion</a></li>
                        {% endif %}
                        <li><a class="nav-cta" href="{{ path('app_home') }}#contact">Réserver</a></li>
                    </ul>
                {% endblock %}
            </nav>
        </header>

        <main>
            {% block body %}{% endblock %}
        </main>

        <footer class="site-footer">
            <div class="site-footer__inner">
                <div>
                    <a class="brand" href="{{ path('app_home') }}">
                    <svg class="brand__die" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="4" stroke-linejoin="round" aria-hidden="true">
                        <polygon points="50,5 90,28 90,72 50,95 10,72 10,28"/>
                        <polygon points="50,18 73,38 50,62 27,38"/>
                        <path d="M50,5 50,18 M10,28 27,38 M90,28 73,38 M27,38 10,72 M73,38 90,72 M50,62 50,95 M50,62 10,72 M50,62 90,72"/>
                    </svg>
                        Dice <strong>Adventure</strong>
                    </a>
                    <p>Maître du jeu passionné — vos aventures de jeu de rôle plateau,<br>dés en main, autour de la table.</p>
                </div>
                <div class="site-footer__links">
                    <a href="{{ path('app_home') }}#aventure">L'aventure</a>
                    <a href="{{ path('app_cgv') }}">C.G.V</a>
                    <a href="{{ path('app_mentions_legales') }}">Mentions légales</a>
                    <a href="{{ path('app_home') }}#contact">Réserver une partie</a>
                </div>
            </div>
            <div class="site-footer__bottom">
                © {{ "now"|date("Y") }} Dice Adventure · L'aventure du dé
            </div>
        </footer>

        {# ---------- Bannière de consentement RGPD ---------- #}
        <div id="rgpd-banner" class="rgpd-banner" role="dialog" aria-label="Consentement aux services tiers" hidden>
            <p>
                🎲 <strong>Votre vie privée</strong> — Ce site ne dépose aucun cookie de suivi ni de publicité,
                mais certains services de Google sont utilisés pour améliorer votre expérience sur notre site.
            </p>
            <p id="rgpd-detail" class="rgpd-banner__detail" hidden>
                Seules les polices d'écriture sont chargées depuis Google&nbsp;Fonts, ce qui transmet votre
                adresse IP à Google. Vous pouvez refuser : le site restera parfaitement lisible.
            </p>
            <div class="rgpd-banner__actions">
                <button type="button" id="rgpd-accept" class="btn btn--primary">Accepter</button>
                <button type="button" id="rgpd-refuse" class="btn btn--dark">Refuser</button>
                <button type="button" id="rgpd-info" class="btn btn--info" aria-expanded="false" aria-controls="rgpd-detail">ℹ️ En savoir plus</button>
            </div>
        </div>
        <script>
            (function () {
                var CLE = 'rgpd-consent';
                var SIX_MOIS = 1000 * 60 * 60 * 24 * 182;
                var banniere = document.getElementById('rgpd-banner');
                if (!banniere) { return; }

                /* Google Fonts n'est injecté qu'après consentement explicite. */
                function chargerPolices() {
                    if (document.getElementById('gfonts-css')) { return; }
                    var pre1 = document.createElement('link');
                    pre1.rel = 'preconnect';
                    pre1.href = 'https://fonts.googleapis.com';
                    var pre2 = document.createElement('link');
                    pre2.rel = 'preconnect';
                    pre2.href = 'https://fonts.gstatic.com';
                    pre2.crossOrigin = 'anonymous';
                    var css = document.createElement('link');
                    css.id = 'gfonts-css';
                    css.rel = 'stylesheet';
                    css.href = 'https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700;800&family=Spectral:ital,wght@0,400;0,500;0,600;1,400&display=swap';
                    document.head.appendChild(pre1);
                    document.head.appendChild(pre2);
                    document.head.appendChild(css);
                }

                function choixMemorise() {
                    try {
                        var brut = localStorage.getItem(CLE);
                        if (!brut) { return null; }
                        var donnees = JSON.parse(brut);
                        /* Le consentement expire après 6 mois : on redemande. */
                        if (!donnees.date || Date.now() - donnees.date > SIX_MOIS) {
                            localStorage.removeItem(CLE);
                            return null;
                        }
                        return donnees.choix;
                    } catch (e) {
                        return null;
                    }
                }

                function memoriser(choix) {
                    try {
                        localStorage.setItem(CLE, JSON.stringify({ choix: choix, date: Date.now() }));
                    } catch (e) { /* stockage indisponible : la bannière reviendra */ }
                    banniere.hidden = true;
                    if (choix === 'accepte') { chargerPolices(); }
                }

                var choix = choixMemorise();
                if (choix === 'accepte') { chargerPolices(); }
                if (choix === null) { banniere.hidden = false; }

                document.getElementById('rgpd-accept').addEventListener('click', function () { memoriser('accepte'); });
                document.getElementById('rgpd-refuse').addEventListener('click', function () { memoriser('refuse'); });

                /* Bouton info : déplie / replie le détail sur les services tiers. */
                var detail = document.getElementById('rgpd-detail');
                var boutonInfo = document.getElementById('rgpd-info');
                boutonInfo.addEventListener('click', function () {
                    detail.hidden = !detail.hidden;
                    boutonInfo.setAttribute('aria-expanded', String(!detail.hidden));
                });
            })();
        </script>
    </body>
</html>
